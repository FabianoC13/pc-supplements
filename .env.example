PORT=5173
HOST=127.0.0.1

# EC2 backend only. Never expose this key in S3, GitHub Pages, or browser code.
CULQI_SECRET_KEY=sk_test_REPLACE_WITH_CULQI_SECRET_KEY
CULQI_API_BASE_URL=https://api.culqi.com

# EC2 backend only. Used for hosted crypto invoices.
NOWPAYMENTS_API_KEY=np_test_REPLACE_WITH_NOWPAYMENTS_API_KEY
NOWPAYMENTS_IPN_SECRET=np_ipn_REPLACE_WITH_NOWPAYMENTS_IPN_SECRET
NOWPAYMENTS_API_BASE_URL=https://api.nowpayments.io
NOWPAYMENTS_PRICE_CURRENCY=pen
NOWPAYMENTS_FIXED_RATE=true
NOWPAYMENTS_FEE_PAID_BY_USER=false
# Optional: pin a specific crypto like usdttrc20. Leave empty to let customers choose.
# NOWPAYMENTS_PAY_CURRENCY=

# Public URLs used in NOWPayments invoice redirects and IPN callbacks.
PUBLIC_SITE_URL=https://YOUR_S3_OR_CLOUDFRONT_DOMAIN
PUBLIC_API_URL=https://YOUR_EC2_API_DOMAIN

# Comma-separated frontend origins allowed to call the EC2 API.
# For S3, replace the placeholder with the S3 website or CloudFront origin.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://fabianoc13.github.io,https://YOUR_S3_OR_CLOUDFRONT_DOMAIN
